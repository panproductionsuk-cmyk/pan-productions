# ==============================================
# SANITY CMS CONFIGURATION
# ==============================================
# Get these from: https://www.sanity.io/manage
VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production

# ==============================================
# STRIPE PAYMENT CONFIGURATION (Backend Only)
# ==============================================
# Get your secret key from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YourSecretKeyHere

# Frontend URL (where your React app runs)
FRONTEND_URL=http://localhost:5173

# Server port (default: 4242)
PORT=4242

# ==============================================
# Newsletter Service Configuration
# ==============================================
# Choose ONE of the following services and configure its credentials

# ==============================================
# OPTION 1: Custom Backend API
# ==============================================
# If you're using your own backend API, no environment variables needed.
# Just make sure your backend API is running at /api/newsletter/subscribe

# ==============================================
# OPTION 2: Mailchimp
# ==============================================
# Get these from: https://mailchimp.com/developer/
# VITE_MAILCHIMP_API_KEY=your_mailchimp_api_key_here
# VITE_MAILCHIMP_AUDIENCE_ID=your_audience_id_here
# VITE_MAILCHIMP_SERVER_PREFIX=us1

# ==============================================
# OPTION 3: ConvertKit
# ==============================================
# Get these from: https://app.convertkit.com/account_settings/advanced_settings
# VITE_CONVERTKIT_API_KEY=your_convertkit_api_key_here
# VITE_CONVERTKIT_FORM_ID=your_form_id_here

# ==============================================
# OPTION 4: SendGrid
# ==============================================
# Get these from: https://app.sendgrid.com/settings/api_keys
# VITE_SENDGRID_API_KEY=your_sendgrid_api_key_here
# VITE_SENDGRID_LIST_ID=your_list_id_here

# ==============================================
# Instructions:
# ==============================================
# 1. Copy this file to .env (remove .example)
# 2. Uncomment the service you want to use
# 3. Add your API credentials
# 4. Update src/lib/newsletter.ts to use your preferred service
# 5. Restart the development server
